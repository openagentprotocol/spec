# Allow environment files to be committed
!.env
!.env.production
# Ignore local development certificates
key.pem
cert.pem
**/node_modules/

# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

**/.DS_Store
**/dist
**/dist-ssr
**/coverage
**/*.local

**/cypress/videos/
**/cypress/screenshots/

# Editor directories and files
**/.vscode/*
!**/.vscode/extensions.json
**/.idea
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?
