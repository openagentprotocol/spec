{
  "openapi": "3.1.0",
  "info": {
    "title": "OAP Observability Service",
    "description": "REST API for the io.oap.observability service — execution traces and audit trail.",
    "version": "2026-04-10",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    }
  },
  "servers": [
    {
      "url": "{endpoint}",
      "description": "OAP-compliant endpoint base URL (from the rest.endpoint field in the /.well-known/oap manifest). All API paths below are appended to this base URL.",
      "variables": {
        "endpoint": {
          "default": "https://your.compliant.oap.endpoint"
        }
      }
    }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/traces": {
      "get": {
        "operationId": "listTraces",
        "summary": "List recent execution traces",
        "tags": ["Execution Traces"],
        "parameters": [
          {
            "name": "agentId",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by agent ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of execution traces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/observability/tracing.json#/$defs/traceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/traces/{traceId}": {
      "parameters": [
        {
          "name": "traceId",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Trace identifier"
        }
      ],
      "get": {
        "operationId": "getTrace",
        "summary": "Get a specific execution trace",
        "tags": ["Execution Traces"],
        "responses": {
          "200": {
            "description": "Execution trace detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/observability/tracing.json#/$defs/executionTrace"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Trace not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "../../schemas/error.json" }
              }
            }
          }
        }
      }
    },
    "/agents/{id}/traces": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Agent identifier"
        }
      ],
      "get": {
        "operationId": "listAgentTraces",
        "summary": "List traces for a specific agent",
        "tags": ["Execution Traces"],
        "responses": {
          "200": {
            "description": "List of execution traces for the agent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/observability/tracing.json#/$defs/traceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Agent not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "../../schemas/error.json" }
              }
            }
          }
        }
      }
    },
    "/agents/{id}/traces/latest": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Agent identifier"
        }
      ],
      "get": {
        "operationId": "getLatestAgentTrace",
        "summary": "Get the latest trace for an agent",
        "tags": ["Execution Traces"],
        "responses": {
          "200": {
            "description": "Latest execution trace for the agent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/observability/tracing.json#/$defs/executionTrace"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Agent or trace not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "../../schemas/error.json" }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    { "name": "Execution Traces", "description": "io.oap.observability.tracing — What happened when an agent processed an event" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication. Required when the discovery manifest's authentication.type is 'bearer'."
      },
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key passed as a request header. Used when authentication.type is 'apiKey' and authentication.in is 'header'."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication required or credentials invalid.",
        "content": {
          "application/json": {
            "schema": { "$ref": "../../schemas/error.json" },
            "example": {
              "error": {
                "code": "UNAUTHORIZED",
                "message": "Bearer token is missing or invalid",
                "details": {}
              }
            }
          }
        }
      }
    }
  }
}
